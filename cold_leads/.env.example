# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# Обязательно: Claude API ключ (получить на console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# 2GIS API ключ (получить на dev.2gis.com, demo-ключ работает с ограничениями)
TWOGIS_API_KEY=demo

# ВКонтакте: токен сервисного аккаунта для чтения данных групп
# Получить: vk.com/dev → Создать приложение → Standalone → ключ доступа
VK_ACCESS_TOKEN=

# Битрикс24: URL вебхука (Битрикс24 → Разработчикам → Входящий вебхук)
# Формат: https://your-domain.bitrix24.ru/rest/USER_ID/WEBHOOK_KEY/
BITRIX24_WEBHOOK_URL=

# Путь к базе данных SQLite (по умолчанию cold_leads.db в папке скрипта)
COLD_LEADS_DB=cold_leads.db

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
